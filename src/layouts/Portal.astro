---
import { t, normLang } from "../lib/i18n";

interface Props {
	title: string;
	lang: string;
	showNav?: boolean;
}
const { title, lang, showNav = true } = Astro.props;
const l = normLang(lang);
const user = Astro.locals.user;

// Build a language-toggle href that preserves the current path + query (e.g. the
// invite ?token= on the claim page).
const url = new URL(Astro.url);
function langHref(to: string) {
	const u = new URL(url);
	u.searchParams.set("lang", to);
	return u.pathname + u.search;
}
---

<!doctype html>
<html lang={l}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title} · J&K Daycare</title>
	</head>
	<body>
		<header class="p-top">
			<a class="p-brand" href="/portal">
				<img src="/logo.svg" alt="" width="30" height="36" />
				<span>J&amp;K</span>
			</a>
			<div class="p-top-right">
				<div class="p-lang" role="group" aria-label={t(l, "language")}>
					<a href={langHref("en")} class={l === "en" ? "on" : ""}>EN</a>
					<a href={langHref("es")} class={l === "es" ? "on" : ""}>ES</a>
				</div>
				{
					showNav && user && (
						<form method="POST" action="/portal/logout">
							<button type="submit" class="p-logout">
								{t(l, "logout")}
							</button>
						</form>
					)
				}
			</div>
		</header>
		<main class="p-main"><slot /></main>

		<style is:global>
			:root {
				--p-coral: #f24150;
				--p-navy: #212149;
				--p-cream: #fdf7ef;
				--p-line: #eadfce;
				--p-muted: #6b6f80;
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				font-family: "Nunito", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
				color: var(--p-navy);
				background: var(--p-cream);
				line-height: 1.55;
			}
			.p-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 0.75rem 1.15rem;
				background: #fff;
				border-bottom: 1px solid var(--p-line);
				position: sticky;
				top: 0;
				z-index: 10;
			}
			.p-brand {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 800;
				font-size: 1.2rem;
				color: var(--p-navy);
				text-decoration: none;
			}
			.p-top-right {
				display: flex;
				align-items: center;
				gap: 0.9rem;
			}
			.p-lang {
				display: inline-flex;
				border: 1.5px solid var(--p-line);
				border-radius: 999px;
				overflow: hidden;
				font-size: 0.8rem;
				font-weight: 800;
			}
			.p-lang a {
				padding: 0.25rem 0.6rem;
				color: var(--p-muted);
				text-decoration: none;
			}
			.p-lang a.on {
				background: var(--p-coral);
				color: #fff;
			}
			.p-logout {
				border: 1.5px solid var(--p-line);
				background: #fff;
				border-radius: 999px;
				padding: 0.4rem 0.9rem;
				cursor: pointer;
				font: inherit;
				font-weight: 700;
				font-size: 0.85rem;
				color: var(--p-navy);
			}
			.p-main {
				max-width: 720px;
				margin: 0 auto;
				padding: 1.5rem 1.15rem 3rem;
			}
			.p-card {
				background: #fff;
				border: 1px solid var(--p-line);
				border-radius: 18px;
				padding: 1.35rem;
			}
			.p-card + .p-card {
				margin-top: 1.15rem;
			}
			.p-card h2 {
				font-size: 1.15rem;
				margin: 0 0 0.9rem;
			}
			.p-muted {
				color: var(--p-muted);
			}
			.p-form {
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
			}
			.p-form label {
				display: flex;
				flex-direction: column;
				gap: 0.3rem;
				font-weight: 700;
				font-size: 0.9rem;
			}
			.p-form input {
				font: inherit;
				font-size: 16px;
				padding: 0.65rem 0.8rem;
				border: 1.5px solid var(--p-line);
				border-radius: 12px;
			}
			.p-form input:focus {
				outline: none;
				border-color: var(--p-coral);
			}
			.p-form button {
				align-self: flex-start;
				background: var(--p-coral);
				color: #fff;
				border: none;
				border-radius: 999px;
				padding: 0.7rem 1.5rem;
				font: inherit;
				font-weight: 800;
				font-size: 1rem;
				cursor: pointer;
			}
			.p-error {
				background: #fdecec;
				color: #b3261e;
				padding: 0.65rem 0.85rem;
				border-radius: 10px;
				font-size: 0.92rem;
				margin: 0 0 0.9rem;
			}
			.p-notice {
				background: #eaf6ec;
				color: #0a7d33;
				padding: 0.65rem 0.85rem;
				border-radius: 10px;
				font-size: 0.92rem;
				margin: 0 0 0.9rem;
			}
		</style>
	</body>
</html>
