---
interface Props {
	title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user;

const path = Astro.url.pathname;
const NAV = [
	{ href: "/admin", label: "Dashboard" },
	{ href: "/admin/children", label: "Children" },
	{ href: "/admin/attendance", label: "Attendance" },
	{ href: "/admin/calendar", label: "Calendar" },
	{ href: "/admin/billing", label: "Billing" },
	{ href: "/admin/announcements", label: "Announcements" },
];
const isActive = (href: string) => (href === "/admin" ? path === "/admin" : path.startsWith(href));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<title>{title} · J&K Admin</title>
	</head>
	<body>
		<header class="a-top">
			<a class="a-brand" href="/admin">
				<img src="/logo.svg" alt="" width="26" height="31" />
				<span>J&amp;K Admin</span>
			</a>
			{
				user && (
					<nav class="a-nav">
						{NAV.map((l) => (
							<a href={l.href} class={isActive(l.href) ? "is-active" : ""}>
								{l.label}
							</a>
						))}
						<a class="a-who" href="/admin/account" title="Account settings">{user.name || user.email}</a>
						<form method="POST" action="/admin/logout">
							<button type="submit" class="a-logout">Log out</button>
						</form>
					</nav>
				)
			}
		</header>
		<main class="a-main"><slot /></main>

		<style is:global>
			:root {
				--a-coral: #f24150;
				--a-navy: #212149;
				--a-cream: #f6f1e8;
				--a-line: #e6eaf2;
				--a-muted: #6b6f80;
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				font-family: "Nunito", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
				color: var(--a-navy);
				background: #f4f6fb;
				line-height: 1.5;
			}
			.a-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 0.7rem 1.25rem;
				background: #fff;
				border-bottom: 1px solid var(--a-line);
				position: sticky;
				top: 0;
				z-index: 10;
			}
			.a-brand {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 800;
				font-size: 1.1rem;
				color: var(--a-navy);
				text-decoration: none;
			}
			.a-nav {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-size: 0.9rem;
				flex-wrap: wrap;
				justify-content: flex-end;
			}
			.a-nav a {
				color: var(--a-navy);
				font-weight: 700;
				text-decoration: none;
			}
			.a-nav a:hover,
			.a-nav a.is-active {
				color: var(--a-coral);
			}
			.a-who {
				color: var(--a-muted);
			}
			@media (max-width: 640px) {
				.a-nav {
					gap: 0.7rem;
					font-size: 0.82rem;
				}
				.a-who {
					display: none;
				}
			}
			.a-logout {
				border: 1px solid var(--a-line);
				background: #fff;
				border-radius: 8px;
				padding: 0.35rem 0.7rem;
				cursor: pointer;
				font: inherit;
				font-size: 0.85rem;
				color: var(--a-navy);
			}
			.a-main {
				max-width: 900px;
				margin: 0 auto;
				padding: 1.5rem 1.25rem 3rem;
			}
			.a-head {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				margin: 0 0 1rem;
			}
			.a-head h1,
			.a-card h1 {
				font-size: 1.5rem;
				margin: 0;
			}
			.a-count {
				background: rgba(242, 65, 80, 0.12);
				color: var(--a-coral);
				font-weight: 800;
				font-size: 0.8rem;
				padding: 0.15rem 0.6rem;
				border-radius: 999px;
			}
			.a-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.25rem;
				align-items: start;
			}
			.a-card {
				background: #fff;
				border: 1px solid var(--a-line);
				border-radius: 14px;
				padding: 1.25rem;
			}
			.a-card h2 {
				font-size: 1.05rem;
				margin: 0 0 0.9rem;
			}
			.a-muted {
				color: var(--a-muted);
			}
			.a-error {
				background: #fdecec;
				color: #b3261e;
				padding: 0.6rem 0.8rem;
				border-radius: 8px;
				font-size: 0.9rem;
				margin: 0 0 0.9rem;
			}
			.a-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.a-list li + li {
				border-top: 1px solid var(--a-line);
			}
			.a-list a {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.6rem 0.25rem;
				text-decoration: none;
				color: var(--a-navy);
			}
			.a-list a:hover {
				color: var(--a-coral);
			}
			.a-flag {
				font-size: 0.7rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				color: #b3261e;
				background: #fdecec;
				padding: 0.1rem 0.4rem;
				border-radius: 6px;
			}
			.a-form {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.a-form label {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
				font-size: 0.85rem;
				font-weight: 700;
			}
			.a-form input,
			.a-form textarea {
				font: inherit;
				padding: 0.55rem 0.7rem;
				border: 1.5px solid var(--a-line);
				border-radius: 10px;
			}
			.a-form input:focus,
			.a-form textarea:focus {
				outline: none;
				border-color: var(--a-coral);
			}
			.a-form button {
				align-self: flex-start;
				background: var(--a-coral);
				color: #fff;
				border: none;
				border-radius: 999px;
				padding: 0.6rem 1.3rem;
				font: inherit;
				font-weight: 800;
				cursor: pointer;
			}
			.a-back {
				display: inline-block;
				margin-bottom: 1rem;
				color: var(--a-coral);
				font-weight: 700;
				text-decoration: none;
				font-size: 0.9rem;
			}
			.a-dl {
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 0.35rem 1rem;
				margin: 0.75rem 0 0;
				font-size: 0.95rem;
			}
			.a-dl dt {
				color: var(--a-muted);
				font-weight: 700;
			}
			.a-dl dd {
				margin: 0;
			}
			.a-notes {
				list-style: none;
				margin: 1rem 0 0;
				padding: 0;
			}
			.a-notes li {
				padding: 0.75rem 0;
				border-top: 1px solid var(--a-line);
			}
			.a-notes p {
				margin: 0 0 0.25rem;
				white-space: pre-wrap;
			}
			.a-meta {
				font-size: 0.78rem;
				color: var(--a-muted);
			}
			@media (max-width: 640px) {
				.a-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
