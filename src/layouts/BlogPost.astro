---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Confetti from "../components/Confetti.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Confetti />
		<Header />
		<main>
			<article>
				{heroImage && <img class="hero-image" width={1020} height={510} src={heroImage} alt="" />}
				<div class="card">
					<p class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>
							)
						}
					</p>
					<h1>{title}</h1>
					<div class="prose"><slot /></div>
				</div>
				<a class="back" href="/blog">← More reads</a>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		flex: 1;
		width: 760px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 1.5rem 1rem 3rem;
		text-align: center;
	}
	.hero-image {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 22px;
		box-shadow: var(--card-shadow-lg);
		margin-bottom: 1.25rem;
	}
	.card {
		background: #fff;
		border-radius: 26px;
		box-shadow: var(--card-shadow-lg);
		padding: clamp(1.5rem, 4vw, 2.75rem);
		text-align: left;
	}
	.date {
		text-align: center;
		color: var(--soft);
		font-weight: 700;
		font-size: 0.9rem;
		margin: 0 0 0.5rem;
	}
	.card h1 {
		text-align: center;
		font-size: clamp(1.9rem, 4.5vw, 2.8rem);
		margin: 0 0 1.5rem;
	}
	.prose {
		color: var(--muted);
		font-size: 1.05rem;
	}
	.prose :global(h2) {
		color: var(--ink);
		margin: 2rem 0 0.6rem;
	}
	.prose :global(h3) {
		color: var(--ink);
		margin: 1.5rem 0 0.5rem;
	}
	.prose :global(a) {
		color: var(--blue);
		font-weight: 700;
	}
	.prose :global(strong) {
		color: var(--ink);
	}
	.back {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		background: rgba(77, 108, 250, 0.1);
		color: var(--blue);
		font-weight: 700;
		font-size: 0.95rem;
		text-decoration: none;
	}
	.back:hover {
		background: rgba(77, 108, 250, 0.18);
	}
</style>
