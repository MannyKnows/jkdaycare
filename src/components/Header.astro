---
import { SITE_TITLE, PHONE, PHONE_HREF } from "../consts";
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<img class="brand-logo" src="/logo.svg" alt="" width="37" height="44" aria-hidden="true" />
			<span>{SITE_TITLE}</span>
		</a>

		<div class="links" id="nav-links">
			<a href="/">Home</a>
			<a href="/programs/">Programs</a>
			<a href="/tuition/">Tuition</a>
			<a href="/about/">About</a>
			<a href="/blog/">Blog</a>
			<a href="/contact/">Contact</a>
			<a class="phone" href={PHONE_HREF}>
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
					><path
						d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .7-.2 1l-2.3 2.2Z"
					></path></svg
				>
				{PHONE}
			</a>
		</div>

		<div class="nav-actions">
			<a class="cta" href="/#tour">Schedule a Tour</a>
			<button
				class="hamburger"
				id="nav-toggle"
				aria-label="Toggle menu"
				aria-expanded="false"
				aria-controls="nav-links"
			>
				<span></span><span></span><span></span>
			</button>
		</div>
	</nav>
</header>

<script>
	const toggle = document.getElementById("nav-toggle");
	const links = document.getElementById("nav-links");
	toggle?.addEventListener("click", () => {
		const open = links?.classList.toggle("open");
		toggle.setAttribute("aria-expanded", String(!!open));
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(255, 252, 245, 0.85);
		backdrop-filter: blur(8px);
		box-shadow: 0 2px 14px rgba(33, 33, 73, 0.08);
	}
	nav {
		max-width: 1080px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.7rem 1.2rem;
	}
	.brand {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.35rem;
		color: var(--ink);
		text-decoration: none;
		white-space: nowrap;
	}
	.brand-logo {
		height: 44px;
		width: auto;
		flex: none;
		border-radius: 0;
	}
	/* The link group (Home … phone) fills the space between the brand and the
	   CTA and centers itself within it. */
	.links {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.1rem;
	}
	.links > a {
		color: var(--muted);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
	}
	.links > a:hover {
		color: var(--blue);
	}
	.phone {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--ink) !important;
		white-space: nowrap;
	}
	.phone svg {
		width: 15px;
		height: 15px;
		color: var(--blue);
	}
	.nav-actions {
		flex: 0 0 auto;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.cta {
		background: var(--blue);
		color: #fff !important;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		padding: 0.55rem 1.1rem;
		border-radius: 999px;
		white-space: nowrap;
		box-shadow: 0 8px 16px rgba(242, 65, 80, 0.28);
	}
	.cta:hover {
		background: #d92f3d;
	}
	.hamburger {
		display: none;
		flex-direction: column;
		gap: 4px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4rem;
	}
	.hamburger span {
		width: 22px;
		height: 2.5px;
		background: var(--ink);
		border-radius: 2px;
	}

	@media (max-width: 760px) {
		nav {
			gap: 0.5rem;
			padding: 0.6rem 0.9rem;
		}
		.brand {
			font-size: 1.1rem;
		}
		.brand-logo {
			height: 38px;
		}
		.hamburger {
			display: flex;
		}
		/* On mobile the links collapse into a dropdown; the CTA stays in the
		   top bar next to the hamburger. */
		.links {
			display: none;
			position: absolute;
			left: 0;
			right: 0;
			top: 100%;
			flex-direction: column;
			align-items: stretch;
			justify-content: flex-start;
			gap: 0.25rem;
			padding: 0.75rem 1.2rem 1.1rem;
			background: var(--paper);
			box-shadow: 0 12px 20px rgba(33, 33, 73, 0.12);
		}
		.links.open {
			display: flex;
		}
		.links > a {
			padding: 0.55rem 0.25rem;
			font-size: 1rem;
		}
		.cta {
			font-size: 0.82rem;
			padding: 0.5rem 0.85rem;
			box-shadow: 0 6px 12px rgba(242, 65, 80, 0.28);
		}
	}
</style>
