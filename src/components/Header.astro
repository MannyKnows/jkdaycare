---
import { SITE_TITLE, PHONE, PHONE_HREF } from "../consts";
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<img class="brand-logo" src="/logo.svg" alt="" width="37" height="44" aria-hidden="true" />
			<span>{SITE_TITLE}</span>
		</a>

		<button
			class="hamburger"
			id="nav-toggle"
			aria-label="Toggle menu"
			aria-expanded="false"
			aria-controls="nav-links"
		>
			<span></span><span></span><span></span>
		</button>

		<div class="links" id="nav-links">
			<a href="/">Home</a>
			<a href="/programs/">Programs</a>
			<a href="/tuition/">Tuition</a>
			<a href="/about/">About</a>
			<a href="/blog/">Blog</a>
			<a class="phone" href={PHONE_HREF}>
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
					><path
						d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .7-.2 1l-2.3 2.2Z"
					></path></svg
				>
				{PHONE}
			</a>
			<button class="ask" id="nav-ask" type="button">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 20l1-4.7A8.5 8.5 0 1 1 21 11.5Z"></path></svg>
				Ask us
			</button>
			<a class="cta" href="/#tour">Schedule a Tour</a>
		</div>
	</nav>
</header>

<script>
	const toggle = document.getElementById("nav-toggle");
	const links = document.getElementById("nav-links");
	toggle?.addEventListener("click", () => {
		const open = links?.classList.toggle("open");
		toggle.setAttribute("aria-expanded", String(!!open));
	});

	// "Ask us" (mobile nav) opens the chat widget and closes the menu.
	document.getElementById("nav-ask")?.addEventListener("click", () => {
		document.dispatchEvent(new CustomEvent("jk:open-chat"));
		links?.classList.remove("open");
		toggle?.setAttribute("aria-expanded", "false");
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(255, 252, 245, 0.85);
		backdrop-filter: blur(8px);
		box-shadow: 0 2px 14px rgba(33, 33, 73, 0.08);
	}
	nav {
		max-width: 1080px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.7rem 1.2rem;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.35rem;
		color: var(--ink);
		text-decoration: none;
		white-space: nowrap;
	}
	.brand-logo {
		height: 44px;
		width: auto;
		flex: none;
		border-radius: 0;
	}
	.links {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.links > a {
		color: var(--muted);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
	}
	.links > a:hover {
		color: var(--blue);
	}
	.phone {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--ink) !important;
		white-space: nowrap;
	}
	.phone svg {
		width: 15px;
		height: 15px;
		color: var(--blue);
	}
	.ask {
		display: none; /* desktop uses the floating chat bubble */
		align-items: center;
		gap: 0.35rem;
		background: none;
		border: none;
		color: var(--ink);
		font-family: inherit;
		font-weight: 700;
		font-size: 1rem;
		white-space: nowrap;
		cursor: pointer;
	}
	.ask svg {
		width: 16px;
		height: 16px;
		color: var(--blue);
	}
	.cta {
		background: var(--blue);
		color: #fff !important;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		padding: 0.55rem 1.1rem;
		border-radius: 999px;
		white-space: nowrap;
		box-shadow: 0 8px 16px rgba(242, 65, 80, 0.28);
	}
	.cta:hover {
		background: #d92f3d;
	}
	.hamburger {
		display: none;
		flex-direction: column;
		gap: 4px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4rem;
	}
	.hamburger span {
		width: 22px;
		height: 2.5px;
		background: var(--ink);
		border-radius: 2px;
	}

	@media (max-width: 760px) {
		.hamburger {
			display: flex;
		}
		.links {
			display: none;
			position: absolute;
			left: 0;
			right: 0;
			top: 100%;
			flex-direction: column;
			align-items: stretch;
			gap: 0.25rem;
			padding: 0.75rem 1.2rem 1.1rem;
			background: var(--paper);
			box-shadow: 0 12px 20px rgba(33, 33, 73, 0.12);
		}
		.links.open {
			display: flex;
		}
		.links > a {
			padding: 0.55rem 0.25rem;
			font-size: 1rem;
		}
		.ask {
			display: inline-flex;
			padding: 0.55rem 0.25rem;
		}
		.cta {
			text-align: center;
			margin-top: 0.35rem;
		}
	}
</style>
