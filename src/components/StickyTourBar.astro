---
import { PHONE_HREF } from "../consts";
---

<div class="sticky-tour" aria-label="Quick actions">
	<a class="call" href={PHONE_HREF}>
		<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
			><path
				d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .7-.2 1l-2.3 2.2Z"
			></path></svg
		>
		Call
	</a>
	<button class="ask" id="sticky-ask" type="button">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
			><path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 20l1-4.7A8.5 8.5 0 1 1 21 11.5Z"></path></svg
		>
		Ask us
	</button>
</div>

<script>
	document.getElementById("sticky-ask")?.addEventListener("click", () => {
		document.dispatchEvent(new CustomEvent("jk:open-chat"));
	});
</script>

<style>
	.sticky-tour {
		display: none;
	}
	/* Only show the anchored bar on smaller screens, where the header CTA scrolls away. */
	@media (max-width: 760px) {
		.sticky-tour {
			position: fixed;
			left: 0;
			right: 0;
			bottom: 0;
			z-index: 50;
			display: flex;
			gap: 0.6rem;
			padding: 0.55rem 0.7rem calc(0.55rem + env(safe-area-inset-bottom));
			background: rgba(255, 252, 245, 0.94);
			backdrop-filter: blur(8px);
			box-shadow: 0 -6px 20px rgba(33, 33, 73, 0.12);
		}
		.sticky-tour a,
		.sticky-tour button {
			flex: 1 1 0;
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			text-decoration: none;
			border: none;
			border-radius: 999px;
			padding: 0.75rem 0.9rem;
			font-size: 0.98rem;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.4rem;
			cursor: pointer;
		}
		.call {
			background: #fff;
			color: var(--coral);
			box-shadow: inset 0 0 0 2px var(--coral);
		}
		.call svg {
			width: 19px;
			height: 19px;
		}
		.ask {
			background: var(--sun);
			color: var(--navy);
		}
		.ask svg {
			width: 18px;
			height: 18px;
		}
	}
</style>
