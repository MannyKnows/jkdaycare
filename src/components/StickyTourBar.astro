---
import { PHONE, PHONE_HREF } from "../consts";
---

<div class="sticky-tour" aria-label="Quick contact">
	<a class="call" href={PHONE_HREF}>
		<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
			><path
				d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .7-.2 1l-2.3 2.2Z"
			></path></svg
		>
		<span>Call</span>
	</a>
	<a class="tour" href="/#tour">Schedule a Tour</a>
</div>

<style>
	.sticky-tour {
		display: none;
	}
	/* Only show the anchored bar on smaller screens, where the header CTA scrolls away. */
	@media (max-width: 760px) {
		.sticky-tour {
			position: fixed;
			left: 0;
			right: 0;
			bottom: 0;
			z-index: 50;
			display: flex;
			gap: 0.6rem;
			padding: 0.6rem 0.8rem calc(0.6rem + env(safe-area-inset-bottom));
			background: rgba(255, 255, 255, 0.92);
			backdrop-filter: blur(8px);
			box-shadow: 0 -6px 20px rgba(33, 33, 73, 0.12);
		}
		.sticky-tour a {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			text-decoration: none;
			border-radius: 999px;
			padding: 0.75rem 1rem;
			font-size: 1rem;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.4rem;
		}
		.call {
			flex: 0 0 auto;
			background: #fff;
			color: var(--blue);
			border: 2px solid var(--blue);
		}
		.call svg {
			width: 18px;
			height: 18px;
		}
		.tour {
			flex: 1;
			background: var(--blue);
			color: #fff;
		}
	}
</style>
