---
import { SITE_TITLE, PHONE, PHONE_HREF, EMAIL, AREA_LINE, HOURS, LICENSE_NUMBER } from "../consts";

const today = new Date();
---

<footer>
	<nav class="foot-nav" aria-label="Footer">
		<a href="/">Home</a>
		<a href="/programs/">Programs</a>
		<a href="/tuition/">Tuition</a>
		<a href="/about/">About</a>
		<a href="/blog/">Blog</a>
	</nav>

	<div class="nap">
		<p class="biz">{SITE_TITLE}</p>
		<address>
			{AREA_LINE}<br />
			<span class="muted">Licensed family child care · MA EEC License #{LICENSE_NUMBER}</span><br />
			<span class="muted">Hours: {HOURS}</span><br />
			Phone: <a href={PHONE_HREF}>{PHONE}</a> · Email: <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
		</address>
		<p class="assist">
			Serving Springfield & Hampden County. Accepting local childcare financial assistance,
			including New England Farm Workers' Council vouchers.
		</p>
	</div>

	<p class="mk-copyright">
		&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.<br />
		by <a href="https://mannyknows.com" class="mk-link" target="_blank" rel="noopener"
			>MK <span class="mk-rocket">🚀</span></a
		>
	</p>
</footer>
<style>
	footer {
		text-align: center;
		padding: 2.5rem 1rem;
	}

	.foot-nav {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 1.5rem;
	}
	.foot-nav a {
		color: var(--muted);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
		transition: color 0.15s ease;
	}
	.foot-nav a:hover {
		color: var(--blue);
	}

	.nap {
		margin-bottom: 1.5rem;
		line-height: 1.7;
	}
	.biz {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.1rem;
		color: var(--ink);
		margin: 0 0 0.25rem;
	}
	.nap address {
		font-style: normal;
		color: var(--ink);
		font-size: 0.95rem;
	}
	.nap .muted {
		color: var(--muted);
	}
	.nap a {
		color: var(--blue);
		text-decoration: none;
	}
	.nap a:hover {
		text-decoration: underline;
	}
	.assist {
		max-width: 46ch;
		margin: 0.75rem auto 0;
		font-size: 0.85rem;
		color: var(--soft);
	}

	/* MK Signature (adapted to the site's light footer) */
	.mk-copyright {
		font-size: 0.78rem;
		color: var(--soft);
		text-align: center;
		line-height: 1.7;
		margin: 0;
	}

	.mk-link {
		background: linear-gradient(90deg, #ff1493, #ff69b4, #ff6347, #ff4500, #ffa500, #ffd700);
		background-size: 300% 100%;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 800;
		transition: background-position 0.4s ease;
	}

	.mk-link:hover {
		background-position: 100% 0;
	}

	.mk-rocket {
		display: inline-block;
		animation: mk-rocket-float 3s ease-in-out infinite;
		background: none !important;
		background-image: none !important;
		-webkit-background-clip: border-box !important;
		background-clip: border-box !important;
		-webkit-text-fill-color: initial !important;
		color: initial !important;
		font-size: 1.15em;
		line-height: 1;
		vertical-align: baseline;
		font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;
	}

	@keyframes mk-rocket-float {
		0%, 100% { transform: translateY(0px) translateX(0px); }
		25% { transform: translateY(-3px) translateX(1.5px); }
		50% { transform: translateY(-1.5px) translateX(-1.5px); }
		75% { transform: translateY(-4px) translateX(1px); }
	}

	@media (prefers-reduced-motion: reduce) {
		.mk-rocket {
			animation: none;
		}
	}
</style>
