---
import { SITE_TITLE } from "../consts";

const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} {SITE_TITLE} · Made with <span class="heart">♥</span> for little ones
</footer>
<style>
	footer {
		text-align: center;
		padding: 2.5rem 1rem;
		color: var(--soft);
		font-size: 0.9rem;
	}
	.heart {
		color: var(--pink);
	}
</style>
