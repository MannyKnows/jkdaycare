---
import { PHONE, SITE_TITLE } from "../consts";
---

<div class="chat" id="chat">
	<button class="chat-toggle" id="chat-toggle" aria-expanded="false" aria-controls="chat-panel">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 20l1-4.7A8.5 8.5 0 1 1 21 11.5Z"></path>
		</svg>
		<span>Ask us</span>
	</button>

	<div class="chat-panel" id="chat-panel" role="dialog" aria-label={`${SITE_TITLE} chat`} hidden>
		<div class="chat-head">
			<strong>{SITE_TITLE} Assistant</strong>
			<button class="chat-close" id="chat-close" aria-label="Close chat">×</button>
		</div>
		<div class="chat-log" id="chat-log" aria-live="polite"></div>
		<form class="chat-form" id="chat-form">
			<input
				id="chat-input"
				type="text"
				autocomplete="off"
				placeholder="Ask about programs, hours, tuition…"
				aria-label="Type your question"
			/>
			<button type="submit" aria-label="Send">Send</button>
		</form>
	</div>
</div>

<script define:vars={{ PHONE }}>
	const toggle = document.getElementById("chat-toggle");
	const panel = document.getElementById("chat-panel");
	const closeBtn = document.getElementById("chat-close");
	const log = document.getElementById("chat-log");
	const form = document.getElementById("chat-form");
	const input = document.getElementById("chat-input");

	// Conversation history sent to the server each turn.
	const history = [];
	let greeted = false;
	let busy = false;

	function bubble(role, text) {
		const el = document.createElement("div");
		el.className = "msg " + role;
		el.textContent = text;
		log.appendChild(el);
		log.scrollTop = log.scrollHeight;
		return el;
	}

	function openPanel() {
		panel.hidden = false;
		toggle.setAttribute("aria-expanded", "true");
		if (!greeted) {
			bubble(
				"bot",
				"Hi! I'm the J&K Daycare assistant. Ask me about our programs, hours, tuition, or scheduling a tour.",
			);
			greeted = true;
		}
		input.focus();
	}
	function closePanel() {
		panel.hidden = true;
		toggle.setAttribute("aria-expanded", "false");
	}

	toggle.addEventListener("click", () => (panel.hidden ? openPanel() : closePanel()));
	closeBtn.addEventListener("click", closePanel);

	// Let other components (e.g. the mobile nav "Ask us" button) open the chat.
	document.addEventListener("jk:open-chat", openPanel);

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		const text = input.value.trim();
		if (!text || busy) return;
		input.value = "";
		bubble("user", text);
		history.push({ role: "user", text });
		busy = true;
		const typing = bubble("bot", "…");

		try {
			const res = await fetch("/api/chat", {
				method: "POST",
				headers: { "content-type": "application/json" },
				body: JSON.stringify({ messages: history.slice(-10) }),
			});
			if (res.status === 503) {
				typing.textContent = `Our chat assistant isn't available right now — please call us at ${PHONE}.`;
				return;
			}
			const data = await res.json().catch(() => ({}));
			const reply =
				(data && data.reply) ||
				`Sorry, something went wrong. Please call us at ${PHONE} and we'll be glad to help.`;
			typing.textContent = reply;
			history.push({ role: "assistant", text: reply });
		} catch {
			typing.textContent = `Network hiccup — please try again, or call us at ${PHONE}.`;
		} finally {
			busy = false;
			log.scrollTop = log.scrollHeight;
		}
	});
</script>

<style>
	.chat-toggle {
		position: fixed;
		right: 20px;
		bottom: 20px;
		z-index: 60;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border: none;
		cursor: pointer;
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1rem;
		padding: 0.8rem 1.2rem;
		border-radius: 999px;
		box-shadow: 0 12px 26px rgba(242, 65, 80, 0.4);
	}
	.chat-toggle svg {
		width: 20px;
		height: 20px;
	}
	.chat-panel {
		position: fixed;
		right: 20px;
		bottom: 84px;
		z-index: 60;
		width: min(360px, calc(100vw - 40px));
		height: min(500px, calc(100vh - 140px));
		display: flex;
		flex-direction: column;
		background: #fff;
		border-radius: 20px;
		box-shadow: 0 24px 60px rgba(33, 33, 73, 0.28);
		overflow: hidden;
	}
	/* The `hidden` attribute must win over the flex display above. */
	.chat-panel[hidden] {
		display: none;
	}
	.chat-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.85rem 1rem;
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
	}
	.chat-close {
		background: none;
		border: none;
		color: #fff;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
		padding: 0 0.25rem;
	}
	.chat-log {
		flex: 1;
		overflow-y: auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		background: #f7f9fc;
	}
	.msg {
		max-width: 85%;
		padding: 0.6rem 0.85rem;
		border-radius: 14px;
		font-size: 0.95rem;
		line-height: 1.45;
		white-space: pre-wrap;
	}
	.msg.user {
		align-self: flex-end;
		background: var(--blue);
		color: #fff;
		border-bottom-right-radius: 4px;
	}
	.msg.bot {
		align-self: flex-start;
		background: #fff;
		color: var(--ink);
		box-shadow: var(--card-shadow);
		border-bottom-left-radius: 4px;
	}
	.chat-form {
		display: flex;
		gap: 0.5rem;
		padding: 0.7rem;
		border-top: 1px solid var(--line);
		background: #fff;
	}
	.chat-form input {
		flex: 1;
		border: 2px solid #e6eaf2;
		border-radius: 999px;
		padding: 0.6rem 0.9rem;
		font-size: 16px;
		font-family: inherit;
	}
	.chat-form input:focus {
		outline: none;
		border-color: var(--blue);
	}
	.chat-form button {
		border: none;
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		border-radius: 999px;
		padding: 0 1.1rem;
		cursor: pointer;
	}
	/* On mobile the chat opens from the nav "Ask us" button, so hide the
	   floating launcher and let the panel rest above the sticky tour bar. */
	@media (max-width: 760px) {
		.chat-toggle {
			display: none;
		}
		.chat-panel {
			bottom: 90px;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.chat-toggle {
			box-shadow: 0 8px 18px rgba(242, 65, 80, 0.35);
		}
	}
</style>
