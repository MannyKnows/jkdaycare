---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION, LAUNCH_DATE } from "../consts";

const launchDate = new Date(LAUNCH_DATE);
const launchLabel = launchDate.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Opening Soon`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main class="coming-soon">
			<section class="hero">
				<p class="eyebrow">JK Daycare</p>
				<h1>Something wonderful is on the way</h1>
				<p class="lede">
					We're opening our doors on <strong>{launchLabel}</strong> — a warm, playful place for your
					little ones to learn, play, and grow.
				</p>

				<div
					id="countdown"
					class="countdown"
					data-launch={LAUNCH_DATE}
					aria-label={`Countdown to ${launchLabel}`}
				>
					<div class="unit"><span class="num" data-days>—</span><span class="lbl">Days</span></div>
					<div class="unit"><span class="num" data-hours>—</span><span class="lbl">Hours</span></div>
					<div class="unit"><span class="num" data-minutes>—</span><span class="lbl">Minutes</span></div>
					<div class="unit"><span class="num" data-seconds>—</span><span class="lbl">Seconds</span></div>
				</div>
			</section>

			<section class="signup" id="signup">
				<h2>Want more information?</h2>
				<p>
					Leave your details and we'll reach out with enrollment information, tour dates, and our
					opening news as soon as we're ready.
				</p>

				<form id="signup-form" novalidate>
					<!-- Honeypot: hidden from people, catches bots. -->
					<div class="hp" aria-hidden="true">
						<label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
					</div>

					<div class="field">
						<label for="name">Name <span class="req">*</span></label>
						<input id="name" name="name" type="text" required autocomplete="name" />
					</div>
					<div class="field">
						<label for="email">Email <span class="req">*</span></label>
						<input id="email" name="email" type="email" required autocomplete="email" />
					</div>
					<div class="field">
						<label for="phone">Phone <span class="req">*</span></label>
						<input id="phone" name="phone" type="tel" required autocomplete="tel" />
					</div>
					<div class="field">
						<label for="address">Address <span class="opt">(optional)</span></label>
						<input id="address" name="address" type="text" autocomplete="street-address" />
					</div>

					<button type="submit">Notify me</button>
					<p class="form-status" role="status" aria-live="polite"></p>
				</form>
			</section>
		</main>

		<footer class="site-footer">&copy; {year} JK Daycare. All rights reserved.</footer>

		<script>
			// ---- Countdown ----
			const cd = document.getElementById("countdown");
			if (cd && cd.dataset.launch) {
				const target = new Date(cd.dataset.launch).getTime();
				const elDays = cd.querySelector("[data-days]");
				const elHours = cd.querySelector("[data-hours]");
				const elMinutes = cd.querySelector("[data-minutes]");
				const elSeconds = cd.querySelector("[data-seconds]");
				const pad = (n: number) => String(n).padStart(2, "0");
				let timer: ReturnType<typeof setInterval> | undefined;

				const tick = () => {
					const diff = target - Date.now();
					if (diff <= 0) {
						cd.innerHTML = '<p class="open-now">We\'re open — welcome! 🎉</p>';
						if (timer) clearInterval(timer);
						return;
					}
					const s = Math.floor(diff / 1000);
					if (elDays) elDays.textContent = String(Math.floor(s / 86400));
					if (elHours) elHours.textContent = pad(Math.floor((s % 86400) / 3600));
					if (elMinutes) elMinutes.textContent = pad(Math.floor((s % 3600) / 60));
					if (elSeconds) elSeconds.textContent = pad(s % 60);
				};

				tick();
				timer = setInterval(tick, 1000);
			}

			// ---- Signup form ----
			const form = document.getElementById("signup-form") as HTMLFormElement | null;
			if (form) {
				const status = form.querySelector(".form-status") as HTMLElement;
				const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				form.addEventListener("submit", async (e) => {
					e.preventDefault();
					status.textContent = "";
					status.className = "form-status";
					const payload = Object.fromEntries(new FormData(form).entries());
					btn.disabled = true;
					const original = btn.textContent;
					btn.textContent = "Sending…";
					try {
						const res = await fetch("/api/signup", {
							method: "POST",
							headers: { "content-type": "application/json" },
							body: JSON.stringify(payload),
						});
						const body = (await res.json().catch(() => ({}))) as {
							ok?: boolean;
							error?: string;
						};
						if (res.ok && body.ok) {
							form.reset();
							status.textContent = "Thanks! We'll be in touch with more information soon.";
							status.classList.add("success");
						} else {
							status.textContent = body.error || "Something went wrong. Please try again.";
							status.classList.add("error");
						}
					} catch {
						status.textContent = "Network error. Please try again.";
						status.classList.add("error");
					} finally {
						btn.disabled = false;
						btn.textContent = original;
					}
				});
			}
		</script>

		<style>
			:global(body) {
				min-height: 100vh;
				margin: 0;
				display: flex;
				flex-direction: column;
				background: linear-gradient(160deg, #fff7f0 0%, #f3f6ff 55%, #eef2ff 100%);
				background-size: cover;
			}
			.coming-soon {
				flex: 1;
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 4em 1em 2em;
				text-align: center;
			}
			.eyebrow {
				text-transform: uppercase;
				letter-spacing: 0.18em;
				font-weight: 700;
				color: var(--accent);
				font-size: 0.9rem;
				margin-bottom: 0.5rem;
			}
			.hero h1 {
				font-size: 2.8rem;
			}
			.lede {
				font-size: 1.2rem;
				color: rgb(var(--gray-dark));
				max-width: 36ch;
				margin: 0.5rem auto 0;
			}

			.countdown {
				display: flex;
				gap: 0.75rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 2.25rem;
			}
			.unit {
				background: #fff;
				border-radius: 14px;
				box-shadow: var(--box-shadow);
				padding: 1rem 1.25rem;
				min-width: 84px;
			}
			.num {
				display: block;
				font-size: 2.6rem;
				font-weight: 700;
				line-height: 1;
				color: var(--accent);
				font-variant-numeric: tabular-nums;
			}
			.lbl {
				display: block;
				margin-top: 0.35rem;
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
			}
			.open-now {
				font-size: 1.6rem;
				font-weight: 700;
				color: var(--accent);
			}

			.signup {
				background: #fff;
				border-radius: 18px;
				box-shadow: var(--box-shadow);
				padding: 2rem;
				max-width: 540px;
				margin: 3rem auto 0;
				text-align: left;
			}
			.signup h2 {
				font-size: 1.75rem;
			}
			.field {
				margin-bottom: 1rem;
			}
			.field label {
				display: block;
				font-weight: 700;
				margin-bottom: 0.35rem;
				font-size: 0.95rem;
			}
			.field input {
				width: 100%;
				box-sizing: border-box;
				padding: 0.7rem 0.8rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				font-size: 16px;
				font-family: inherit;
			}
			.field input:focus {
				outline: 2px solid var(--accent);
				outline-offset: 1px;
				border-color: var(--accent);
			}
			.req {
				color: var(--accent);
			}
			.opt {
				color: rgb(var(--gray));
				font-weight: 400;
				font-size: 0.85em;
			}
			button[type="submit"] {
				width: 100%;
				margin-top: 0.5rem;
				padding: 0.8rem 1rem;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 10px;
				font-size: 1.05rem;
				font-weight: 700;
				font-family: inherit;
				cursor: pointer;
			}
			button[type="submit"]:hover {
				background: var(--accent-dark);
			}
			button[type="submit"]:disabled {
				opacity: 0.65;
				cursor: default;
			}
			.form-status {
				margin: 1rem 0 0;
				min-height: 1.2em;
				font-size: 0.95rem;
			}
			.form-status.success {
				color: #0a7d33;
			}
			.form-status.error {
				color: #c0341d;
			}
			.hp {
				position: absolute;
				left: -9999px;
				width: 1px;
				height: 1px;
				overflow: hidden;
			}

			.site-footer {
				text-align: center;
				padding: 2rem 1rem 3rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.2rem;
				}
				.num {
					font-size: 2rem;
				}
				.unit {
					min-width: 70px;
					padding: 0.85rem 1rem;
				}
				.signup {
					padding: 1.5rem;
				}
			}
		</style>
	</body>
</html>
