---
import Layout from "../layouts/Page.astro";
import TrustBadges from "../components/TrustBadges.astro";
import PeekInside from "../components/PeekInside.astro";
import ProgramCard from "../components/ProgramCard.astro";
import DailySchedule from "../components/DailySchedule.astro";
import VideoReel from "../components/VideoReel.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { PROGRAMS } from "../data/site";
import {
	SITE_DESCRIPTION,
	EMAIL,
	LOCALITY,
	REGION,
	POSTAL_CODE,
	MAX_CAPACITY,
	TIKTOK_URL,
	GOOGLE_PROFILE_URL,
} from "../consts";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// Show the curated "featured" posts on the home page; fall back to the most
// recent if fewer than four are flagged.
const featuredPosts = allPosts.filter((p) => p.data.featured);
const posts = (featuredPosts.length >= 4 ? featuredPosts : allPosts).slice(0, 4);

const localBusiness = {
	"@context": "https://schema.org",
	"@type": "ChildCare",
	"@id": "https://jkdaycare.com",
	name: "J&K Daycare",
	description: SITE_DESCRIPTION,
	url: "https://jkdaycare.com",
	telephone: "+1-413-486-5978",
	email: EMAIL,
	image: "https://jkdaycare.com/montessori.jpg",
	address: {
		"@type": "PostalAddress",
		addressLocality: LOCALITY,
		addressRegion: REGION,
		postalCode: POSTAL_CODE,
		addressCountry: "US",
	},
	areaServed: [
		"East Forest Park, Springfield, MA",
		"Sixteen Acres, Springfield, MA",
		"Springfield, MA 01118",
	],
	openingHoursSpecification: [
		{
			"@type": "OpeningHoursSpecification",
			dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			opens: "08:00",
			closes: "17:00",
		},
	],
	knowsAbout: [
		"Bilingual early education",
		"Montessori-inspired learning",
		"Play-based learning",
		"Early childhood education",
		"Preschool",
		"Pre-K",
	],
	knowsLanguage: ["English", "Spanish"],
	geo: {
		"@type": "GeoCoordinates",
		latitude: 42.101,
		longitude: -72.54,
	},
	priceRange: "$$",
	sameAs: [TIKTOK_URL, GOOGLE_PROFILE_URL],
	maximumAttendeeCapacity: MAX_CAPACITY,
};
---

<Layout
	title="Bilingual Montessori-Inspired Daycare in Springfield, MA 01118 | J&K Daycare"
	description={SITE_DESCRIPTION}
	image="/montessori.jpg"
	confetti={true}
	jsonLd={localBusiness}
>
	<div class="home">
		<section class="hero">
			<p class="eyebrow">Bilingual · Montessori-inspired · East Forest Park</p>
			<h1>Bilingual, Montessori-Inspired Childcare in Springfield, MA</h1>
			<p class="sub">
				Welcome to J&amp;K Daycare — a small, licensed family child care in East Forest Park. We
				blend <strong>Montessori-inspired</strong>, play-based learning in a warm,{" "}
				<strong>bilingual (English &amp; Spanish)</strong> home for up to six children ages 2–5, where
				every child gets real attention.
			</p>
			<div class="hero-cta">
				<a class="btn-primary" href="#tour">Schedule a Private Tour</a>
				<a class="btn-secondary" href="/programs/">View Programs & Pricing</a>
			</div>
		</section>

		<section class="trust">
			<TrustBadges />
		</section>

		<PeekInside />

		<section class="section programs">
			<h2>One small group, ages 2–5</h2>
			<p class="section-lede">
				We care for up to six children in one warm, mixed-age setting — with play tailored to where
				each child is. Here's what we focus on at each stage.
			</p>
			<div class="prog-grid">
				{PROGRAMS.map((p) => <ProgramCard program={p} />)}
			</div>
		</section>

		<section class="section daywrap">
			<DailySchedule items={PROGRAMS[0].sampleDay} title="A typical day at J&K" />
			<div class="assist">
				<h3>Financial assistance & vouchers</h3>
				<p>
					We accept local childcare financial assistance, including New England Farm Workers'
					Council (NEFWC) vouchers.
				</p>
				<a class="btn-secondary" href="/tuition/">See tuition & estimate cost</a>
			</div>
		</section>

		<VideoReel />


		{
			posts.length > 0 && (
				<section class="section reads">
					<h2>From our blog</h2>
					<ul class="reads-list">
						{posts.map((p) => (
							<li>
								<a href={`/blog/${p.id}/`}>
									<span class="r-title">{p.data.title}</span>
									<span class="r-date">
										<FormattedDate date={p.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
					<a class="more-reads" href="/blog">Read more</a>
				</section>
			)
		}
	</div>


	<style>
		.home {
			width: 1000px;
			max-width: calc(100% - 2em);
			margin: 0 auto;
			padding: 2.5rem 1rem 3rem;
		}
		.hero {
			text-align: center;
			max-width: 720px;
			margin: 0 auto;
		}
		.eyebrow {
			display: inline-block;
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 700;
			color: var(--blue);
			background: rgba(242, 65, 80, 0.1);
			padding: 0.3rem 0.95rem;
			border-radius: 999px;
			font-size: 0.9rem;
			margin: 0 0 0.6rem;
		}
		.hero h1 {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			font-size: clamp(2.1rem, 5vw, 3.1rem);
			line-height: 1.1;
			margin: 0.3rem 0 0;
		}
		.sub {
			font-size: 1.18rem;
			color: var(--muted);
			max-width: 60ch;
			margin: 1rem auto 0;
		}
		.hero-cta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			justify-content: center;
			margin-top: 1.6rem;
		}
		.btn-primary,
		.btn-secondary {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 700;
			text-decoration: none;
			border-radius: 999px;
			padding: 0.85rem 1.5rem;
			font-size: 1.05rem;
			display: inline-block;
			border: none;
			cursor: pointer;
		}
		.btn-primary {
			background: var(--blue);
			color: #fff;
			box-shadow: 0 10px 20px rgba(242, 65, 80, 0.3);
		}
		.btn-primary:hover {
			background: #d92f3d;
		}
		.btn-secondary {
			background: #fff;
			color: var(--blue);
			box-shadow: var(--card-shadow);
		}
		.btn-primary.wide {
			width: 100%;
			margin-top: 0.5rem;
		}

		.trust {
			margin: 2.5rem 0 0;
		}
		.section {
			margin: 3.25rem 0 0;
		}
		.section > h2 {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			font-size: 1.8rem;
			text-align: center;
			margin: 0 0 0.4rem;
		}
		.section-lede {
			text-align: center;
			color: var(--muted);
			margin: 0 0 1.5rem;
		}
		.prog-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 1.25rem;
		}
		.daywrap {
			display: grid;
			grid-template-columns: 1.3fr 1fr;
			gap: 1.25rem;
			align-items: start;
		}
		.assist {
			background: #212149;
			color: #fff;
			border-radius: 22px;
			padding: 1.75rem;
			text-align: left;
		}
		.assist h3 {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			font-size: 1.25rem;
			color: #fff;
			margin: 0 0 0.6rem;
		}
		.assist p {
			color: rgba(255, 255, 255, 0.85);
			margin: 0 0 1.25rem;
		}
		.assist .btn-secondary {
			background: #fff;
			color: #212149;
		}

		.tour-card {
			background: #fff;
			border-radius: 26px;
			box-shadow: var(--card-shadow-lg);
			padding: 2.25rem;
			max-width: 560px;
			margin: 0 auto;
			text-align: left;
		}
		.tour-card h2 {
			font-family: "Baloo 2", "Nunito", sans-serif;
			font-weight: 800;
			font-size: 1.8rem;
			margin: 0 0 0.25rem;
			text-align: left;
		}
		.tour-card > p {
			color: var(--muted);
			margin: 0 0 1.25rem;
		}
		.field {
			margin-bottom: 1rem;
		}
		.field label {
			display: block;
			font-weight: 700;
			margin-bottom: 0.35rem;
			font-size: 0.95rem;
		}
		.field input {
			width: 100%;
			box-sizing: border-box;
			padding: 0.75rem 0.9rem;
			border: 2px solid #e6eaf2;
			border-radius: 14px;
			font-size: 16px;
			font-family: inherit;
		}
		.field input:focus {
			outline: none;
			border-color: var(--blue);
			box-shadow: 0 0 0 4px rgba(242, 65, 80, 0.15);
		}
		.req {
			color: var(--pink);
		}
		.opt {
			color: var(--soft);
			font-weight: 400;
			font-size: 0.85em;
		}
		.hp {
			position: absolute;
			left: -9999px;
			width: 1px;
			height: 1px;
			overflow: hidden;
		}
		.form-status {
			margin: 1rem 0 0;
			min-height: 1.2em;
			font-size: 0.95rem;
			font-weight: 700;
		}
		.form-status.success {
			color: #0a7d33;
		}
		.form-status.error {
			color: #d23b3b;
		}

		.reads {
			max-width: 560px;
			margin-left: auto;
			margin-right: auto;
			text-align: center;
		}
		.reads-list {
			list-style: none;
			margin: 0;
			padding: 0;
			background: #fff;
			border-radius: 18px;
			box-shadow: var(--card-shadow);
			overflow: hidden;
			text-align: left;
		}
		.reads-list li + li {
			border-top: 1px solid var(--line);
		}
		.reads-list li {
			margin: 0;
		}
		.reads-list a {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1rem;
			padding: 0.7rem 1.1rem;
			text-decoration: none;
			color: var(--ink);
		}
		.reads-list a:hover {
			background: #f6f9fc;
		}
		.r-title {
			font-weight: 700;
			font-size: 0.98rem;
		}
		.r-date {
			color: var(--soft);
			font-size: 0.8rem;
			white-space: nowrap;
		}
		.more-reads {
			display: inline-block;
			margin-top: 1rem;
			padding: 0.4rem 1.1rem;
			border-radius: 999px;
			background: rgba(242, 65, 80, 0.1);
			color: var(--blue);
			font-weight: 700;
			font-size: 0.9rem;
			text-decoration: none;
		}

		@media (max-width: 760px) {
			.prog-grid,
			.daywrap {
				grid-template-columns: 1fr;
			}
			.tour-card {
				padding: 1.5rem;
			}
		}
	</style>
</Layout>
