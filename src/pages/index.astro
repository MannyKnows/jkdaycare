				font-size: 1.7rem;
				color: #fff;
				margin: 0 0 0.6rem;
			}
			.enroll p { color: rgba(255, 255, 255, 0.92); margin: 0 0 1.5rem; }
			.enroll .btn-call {
				background: #fff;
				color: #4d6cfa;
				box-shadow: 0 10px 20px rgba(0, 0, 0, 0.18);
			}

			/* Featured blog posts — compact list */
			.reads {
				max-width: 540px;
				margin: 3rem auto 0;
				text-align: center;
			}
			.reads h2 {
				font-family: "Baloo 2", "Nunito", sans-serif;
				font-weight: 700;
				font-size: 1.4rem;
				margin: 0 0 1rem;
			}
			.reads-list {
				list-style: none;
				margin: 0;
				padding: 0;
				background: #fff;
				border-radius: 18px;
				box-shadow: 0 12px 30px rgba(45, 58, 85, 0.08);
				overflow: hidden;
				text-align: left;
			}
			.reads-list li + li { border-top: 1px solid #eef1f6; }
			.reads-list a {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				padding: 0.7rem 1.1rem;
				text-decoration: none;
				color: #2b3a55;
				transition: background 0.15s ease;
			}
			.reads-list a:hover { background: #f6f9fc; }
			.r-title { font-weight: 700; font-size: 0.98rem; }
			.reads-list a:hover .r-title { color: #4d6cfa; }
			.r-date {
				color: #8b94a6;
				font-size: 0.8rem;
				white-space: nowrap;
			}
			.more-reads {
				display: inline-block;
				margin-top: 1rem;
				padding: 0.4rem 1.1rem;
				border-radius: 999px;
				background: rgba(77, 108, 250, 0.1);
				color: #4d6cfa;
				font-weight: 700;
				font-size: 0.9rem;
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.more-reads:hover { background: rgba(77, 108, 250, 0.18); }


			@media (max-width: 720px) {
				main { padding-top: 2.5em; }
				.confetti i:nth-child(n + 7) { display: none; }
				.cards { grid-template-columns: 1fr; }
				.info,
				.signup,
				.enroll { padding: 1.5rem; }
			}
			@media (prefers-reduced-motion: reduce) {
				.confetti i,
				.num.pop,
				.hero,
				.info,
				.curriculum,
				.signup,
				.enroll,
				.reads {
					animation: none !important;
