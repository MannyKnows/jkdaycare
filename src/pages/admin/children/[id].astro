---
export const prerender = false;
import { env } from "cloudflare:workers";
import Admin from "../../../layouts/Admin.astro";
import { today, nowISO, fmtTime, fmtDateTime, localDay } from "../../../lib/day";
import { randomToken, hashToken } from "../../../lib/auth";
import { isKind } from "../../../lib/activities";
import { fmtMoney, parseDollars } from "../../../lib/money";
import QuickLog from "../../../components/QuickLog.astro";

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect("/admin/children");

const day = today();

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const intent = String(form.get("intent") ?? "");
	const s = (k: string) => String(form.get(k) ?? "").trim() || null;

	if (intent === "edit") {
		await env.DB.prepare(
			`UPDATE children SET first_name = ?2, last_name = ?3, dob = ?4, allergies = ?5,
			 parent_name = ?6, parent_email = ?7, parent_phone = ?8 WHERE id = ?1`,
		)
			.bind(
				id,
				String(form.get("first_name") ?? "").trim() || "Child",
				s("last_name"),
				s("dob"),
				s("allergies"),
				s("parent_name"),
				(s("parent_email") ?? "")?.toLowerCase() || null,
				s("parent_phone"),
			)
			.run();
	} else if (intent === "activity" || intent === "quicklog") {
		const kind = String(form.get("kind") ?? "note");
		const detail = s("detail");
		if (isKind(kind)) {
			await env.DB.prepare(
				`INSERT INTO activities (child_id, author_id, kind, detail) VALUES (?1, ?2, ?3, ?4)`,
			)
				.bind(id, Astro.locals.user?.id ?? null, kind, detail)
				.run();
		}
	} else if (intent === "note") {
		const body = s("body");
		if (body) {
			await env.DB.prepare(`INSERT INTO notes (child_id, author_id, body) VALUES (?1, ?2, ?3)`)
				.bind(id, Astro.locals.user?.id ?? null, body)
				.run();
		}
	} else if (intent === "in") {
		await env.DB.prepare(
			`INSERT INTO attendance (child_id, day, check_in) VALUES (?1, ?2, ?3)
			 ON CONFLICT(child_id, day) DO UPDATE SET check_in = COALESCE(attendance.check_in, excluded.check_in)`,
		)
			.bind(id, day, nowISO())
			.run();
	} else if (intent === "out") {
		await env.DB.prepare(
			`INSERT INTO attendance (child_id, day, check_out) VALUES (?1, ?2, ?3)
			 ON CONFLICT(child_id, day) DO UPDATE SET check_out = excluded.check_out`,
		)
			.bind(id, day, nowISO())
			.run();
	} else if (intent === "photo") {
		const file = form.get("photo");
		if (file instanceof File && file.size > 0) {
			if (!file.type.startsWith("image/")) {
				return Astro.redirect(`/admin/children/${id}?perr=type`);
			}
			if (file.size > 8 * 1024 * 1024) {
				return Astro.redirect(`/admin/children/${id}?perr=size`);
			}
			const ext = (file.name.split(".").pop() || "jpg").toLowerCase().replace(/[^a-z0-9]/g, "") || "jpg";
			const key = `child-${id}/${Date.now()}-${crypto.randomUUID().slice(0, 8)}.${ext}`;
			await env.MEDIA.put(key, await file.arrayBuffer(), {
				httpMetadata: { contentType: file.type },
			});
			await env.DB.prepare(
				"INSERT INTO media (child_id, author_id, r2_key, content_type, caption) VALUES (?1, ?2, ?3, ?4, ?5)",
			)
				.bind(id, Astro.locals.user?.id ?? null, key, file.type, s("caption"))
				.run();
		}
	} else if (intent === "delphoto") {
		const mid = Number(form.get("media_id"));
		if (Number.isInteger(mid)) {
			// Scope to this child so a crafted id can't delete another child's photo.
			const m = await env.DB.prepare("SELECT r2_key FROM media WHERE id = ?1 AND child_id = ?2")
				.bind(mid, id)
				.first<{ r2_key: string }>();
			if (m) {
				await env.MEDIA.delete(m.r2_key);
				await env.DB.prepare("DELETE FROM media WHERE id = ?1").bind(mid).run();
			}
		}
	} else if (intent === "invite") {
		const email = String(form.get("email") ?? "").trim().toLowerCase() || null;
		if (email) {
			const token = randomToken();
			const expires = new Date(Date.now() + 7 * 86_400_000).toISOString();
			await env.DB.prepare(
				`INSERT INTO parent_invites (token_hash, child_id, email, created_by, expires_at)
				 VALUES (?1, ?2, ?3, ?4, ?5)`,
			)
				.bind(await hashToken(token), id, email, Astro.locals.user?.id ?? null, expires)
				.run();
			// Round-trip the raw token once so the owner can copy the link. It's
			// single-use and expires; only its hash is stored.
			return Astro.redirect(`/admin/children/${id}?invite=${token}`);
		}
	} else if (intent === "unlink") {
		const uid = Number(form.get("user_id"));
		if (Number.isInteger(uid)) {
			await env.DB.prepare(`DELETE FROM child_parents WHERE child_id = ?1 AND user_id = ?2`)
				.bind(id, uid)
				.run();
		}
	} else if (intent === "plan") {
		const cents = parseDollars(String(form.get("amount") ?? ""));
		const cadence = String(form.get("cadence")) === "monthly" ? "monthly" : "weekly";
		const active = form.get("active") ? 1 : 0;
		if (cents && cents > 0) {
			await env.DB.prepare(
				`INSERT INTO billing_plans (child_id, amount_cents, cadence, active, updated_at)
				 VALUES (?1, ?2, ?3, ?4, datetime('now'))
				 ON CONFLICT(child_id) DO UPDATE SET
				   amount_cents = excluded.amount_cents, cadence = excluded.cadence,
				   active = excluded.active, updated_at = excluded.updated_at`,
			)
				.bind(id, cents, cadence, active)
				.run();
		}
		return Astro.redirect(`/admin/children/${id}#billing`);
	}
	return Astro.redirect(`/admin/children/${id}`);
}

const child = await env.DB.prepare("SELECT * FROM children WHERE id = ?1")
	.bind(id)
	.first<{
		id: number;
		first_name: string;
		last_name: string | null;
		dob: string | null;
		allergies: string | null;
		parent_name: string | null;
		parent_email: string | null;
		parent_phone: string | null;
	}>();
if (!child) return Astro.redirect("/admin/children");

const [attRes, actRes, noteRes] = await env.DB.batch([
	env.DB.prepare(`SELECT check_in, check_out FROM attendance WHERE child_id = ?1 AND day = ?2`).bind(id, day),
	env.DB.prepare(
		`SELECT kind, detail, created_at FROM activities WHERE child_id = ?1 ORDER BY created_at DESC LIMIT 40`,
	).bind(id),
	env.DB.prepare(
		`SELECT n.body, n.created_at, u.name AS author FROM notes n
		 LEFT JOIN users u ON u.id = n.author_id WHERE n.child_id = ?1 ORDER BY n.created_at DESC LIMIT 40`,
	).bind(id),
]);

const attend = attRes.results[0] as { check_in: string | null; check_out: string | null } | undefined;
const activities = actRes.results as { kind: string; detail: string | null; created_at: string }[];
const notes = noteRes.results as { body: string; created_at: string; author: string | null }[];

const todaysActivities = activities.filter((a) => localDay(a.created_at) === day);

const { results: parents } = await env.DB.prepare(
	`SELECT u.id, u.email, u.name FROM child_parents cp JOIN users u ON u.id = cp.user_id
	 WHERE cp.child_id = ?1 ORDER BY u.name`,
)
	.bind(id)
	.all<{ id: number; email: string; name: string | null }>();

const { results: photos } = await env.DB.prepare(
	`SELECT id, caption, created_at FROM media WHERE child_id = ?1 ORDER BY created_at DESC LIMIT 60`,
)
	.bind(id)
	.all<{ id: number; caption: string | null; created_at: string }>();
const todaysPhotos = photos.filter((p) => localDay(p.created_at) === day);
const earlierPhotos = photos.filter((p) => localDay(p.created_at) !== day);

const photoError =
	Astro.url.searchParams.get("perr") === "size"
		? "That photo is over 8 MB — please pick a smaller one."
		: Astro.url.searchParams.get("perr") === "type"
			? "That file isn't an image."
			: "";

// A freshly generated invite token is round-tripped via the URL so the owner can
// copy the link once; only its hash is stored server-side.
const inviteToken = Astro.url.searchParams.get("invite");
const inviteLink = inviteToken ? `${Astro.url.origin}/portal/claim?token=${inviteToken}` : "";

const plan = await env.DB.prepare(
	`SELECT amount_cents, cadence, active FROM billing_plans WHERE child_id = ?1`,
)
	.bind(id)
	.first<{ amount_cents: number; cadence: string; active: number }>();
const dueRow = await env.DB.prepare(
	`SELECT COALESCE(SUM(amount_cents), 0) AS due FROM charges WHERE child_id = ?1 AND status = 'due'`,
)
	.bind(id)
	.first<{ due: number }>();
const balanceDue = dueRow?.due ?? 0;

// Age from DOB, shown as months under 2 years, else years.
function age(dob: string | null): string {
	if (!dob) return "";
	const b = new Date(dob + "T00:00:00");
	if (isNaN(b.getTime())) return "";
	const now = new Date();
	let months = (now.getFullYear() - b.getFullYear()) * 12 + (now.getMonth() - b.getMonth());
	if (now.getDate() < b.getDate()) months--;
	if (months < 0) return "";
	return months < 24 ? `${months} mo` : `${Math.floor(months / 12)} yrs`;
}

const KIND_LABEL: Record<string, string> = {
	meal: "🍎 Meal",
	nap: "😴 Nap",
	mood: "🙂 Mood",
	activity: "🧩 Activity",
	note: "📝 Note",
	diaper: "🚼 Diaper",
};

const status = attend?.check_out ? "out" : attend?.check_in ? "in" : "none";
const fullName = `${child.first_name} ${child.last_name ?? ""}`.trim();
---

<Admin title={fullName}>
	<a class="a-back" href="/admin/children">← Children</a>

	<section class="a-card a-profile-head">
		<div>
			<h1>{fullName}</h1>
			<p class="a-sub">
				{child.dob && <span>{age(child.dob)}</span>}
				{child.allergies && <span class="a-flag">{child.allergies}</span>}
			</p>
		</div>
		<div class="a-att-inline">
			{
				status === "none" && (
					<form method="POST">
						<input type="hidden" name="intent" value="in" />
						<button class="a-btn-in" type="submit">Check in</button>
					</form>
				)
			}
			{
				status === "in" && (
					<>
						<span class="a-att-badge">In {fmtTime(attend?.check_in)}</span>
						<form method="POST">
							<input type="hidden" name="intent" value="out" />
							<button class="a-btn-out" type="submit">Check out</button>
						</form>
					</>
				)
			}
			{status === "out" && <span class="a-att-badge done">In {fmtTime(attend?.check_in)} · Out {fmtTime(attend?.check_out)}</span>}
		</div>
	</section>

	<div class="a-grid">
		<section class="a-card">
			<h2>Today's report</h2>
			<p class="a-quick-label">Quick log — one tap:</p>
			<QuickLog childId={id} />
			<details class="a-detailed">
				<summary>Add with a detail</summary>
				<form method="POST" class="a-log">
					<input type="hidden" name="intent" value="activity" />
					<select name="kind" aria-label="Kind">
						<option value="meal">🍎 Meal</option>
						<option value="nap">😴 Nap</option>
						<option value="diaper">🚼 Diaper</option>
						<option value="mood">🙂 Mood</option>
						<option value="activity">🧩 Activity</option>
						<option value="note">📝 Note</option>
					</select>
					<input name="detail" placeholder="e.g. Napped 12:30–2:00" />
					<button type="submit">Log</button>
				</form>
			</details>

			{
				todaysActivities.length === 0 ? (
					<p class="a-muted" style="margin-top:1rem">Nothing logged today yet.</p>
				) : (
					<ul class="a-feed">
						{todaysActivities.map((a) => (
							<li>
								<span class="a-feed-kind">{KIND_LABEL[a.kind] ?? a.kind}</span>
								{a.detail && <span class="a-feed-detail">{a.detail}</span>}
								<span class="a-meta">{fmtTime(a.created_at)}</span>
							</li>
						))}
					</ul>
				)
			}

			{
				activities.length > todaysActivities.length && (
					<details class="a-earlier">
						<summary>Earlier entries</summary>
						<ul class="a-feed">
							{activities.slice(todaysActivities.length).map((a) => (
								<li>
									<span class="a-feed-kind">{KIND_LABEL[a.kind] ?? a.kind}</span>
									{a.detail && <span class="a-feed-detail">{a.detail}</span>}
									<span class="a-meta">{fmtDateTime(a.created_at)}</span>
								</li>
							))}
						</ul>
					</details>
				)
			}
		</section>

		<section class="a-card">
			<h2>Details</h2>
			<form method="POST" class="a-form">
				<input type="hidden" name="intent" value="edit" />
				<label>First name<input name="first_name" value={child.first_name} required /></label>
				<label>Last name<input name="last_name" value={child.last_name ?? ""} /></label>
				<label>Date of birth<input name="dob" type="date" value={child.dob ?? ""} /></label>
				<label>Allergies / health<input name="allergies" value={child.allergies ?? ""} /></label>
				<label>Parent name<input name="parent_name" value={child.parent_name ?? ""} /></label>
				<label>Parent email<input name="parent_email" type="email" value={child.parent_email ?? ""} /></label>
				<label>Parent phone<input name="parent_phone" value={child.parent_phone ?? ""} /></label>
				<button type="submit">Save changes</button>
			</form>
		</section>
	</div>

	<section class="a-card" style="margin-top:1.25rem">
		<h2>Photos</h2>
		<p class="a-muted" style="margin-top:-0.5rem;font-size:0.85rem">
			Share moments from the day — parents see these in their portal right away.
		</p>
		{photoError && <p class="a-error">{photoError}</p>}
		<form method="POST" enctype="multipart/form-data" class="a-photo-form">
			<input type="hidden" name="intent" value="photo" />
			<input name="photo" type="file" accept="image/*" required />
			<input name="caption" type="text" placeholder="Caption (optional)" />
			<button type="submit">Upload</button>
		</form>

		{
			todaysPhotos.length > 0 && (
				<div class="a-photo-grid">
					{todaysPhotos.map((p) => (
						<figure class="a-photo">
							<a href={`/media/${p.id}`} target="_blank">
								<img src={`/media/${p.id}`} alt={p.caption ?? "Photo"} loading="lazy" />
							</a>
							<figcaption>
								<span>
									{p.caption && <em>{p.caption} · </em>}
									{fmtTime(p.created_at)}
								</span>
								<form method="POST" onsubmit="return confirm('Delete this photo?')">
									<input type="hidden" name="intent" value="delphoto" />
									<input type="hidden" name="media_id" value={p.id} />
									<button class="a-del" type="submit" title="Delete photo">
										×
									</button>
								</form>
							</figcaption>
						</figure>
					))}
				</div>
			)
		}
		{todaysPhotos.length === 0 && <p class="a-muted" style="margin-top:0.9rem">No photos yet today.</p>}
		{
			earlierPhotos.length > 0 && (
				<details class="a-earlier">
					<summary>Earlier photos ({earlierPhotos.length})</summary>
					<div class="a-photo-grid">
						{earlierPhotos.map((p) => (
							<figure class="a-photo">
								<a href={`/media/${p.id}`} target="_blank">
									<img src={`/media/${p.id}`} alt={p.caption ?? "Photo"} loading="lazy" />
								</a>
								<figcaption>
									<span>
										{p.caption && <em>{p.caption} · </em>}
										{fmtDateTime(p.created_at)}
									</span>
									<form method="POST" onsubmit="return confirm('Delete this photo?')">
										<input type="hidden" name="intent" value="delphoto" />
										<input type="hidden" name="media_id" value={p.id} />
										<button class="a-del" type="submit" title="Delete photo">
											×
										</button>
									</form>
								</figcaption>
							</figure>
						))}
					</div>
				</details>
			)
		}
	</section>

	<section class="a-card" style="margin-top:1.25rem" id="billing">
		<h2>Billing plan</h2>
		<p class="a-muted" style="margin-top:-0.5rem;font-size:0.85rem">
			{
				plan
					? `Current: ${fmtMoney(plan.amount_cents)} / ${plan.cadence === "monthly" ? "month" : "week"}${plan.active ? "" : " (paused)"} · ${balanceDue > 0 ? `${fmtMoney(balanceDue)} due` : "paid up"}`
					: "No plan yet — set one so charges can be generated."
			}
			<a href="/admin/billing" class="a-link" style="margin-left:0.4rem">Open billing →</a>
		</p>
		<form method="POST" class="a-log">
			<input type="hidden" name="intent" value="plan" />
			<input
				name="amount"
				type="number"
				step="0.01"
				min="0.01"
				required
				placeholder="$ amount"
				value={plan ? (plan.amount_cents / 100).toFixed(2) : ""}
			/>
			<select name="cadence" aria-label="Cadence">
				<option value="weekly" selected={!plan || plan.cadence === "weekly"}>per week</option>
				<option value="monthly" selected={plan?.cadence === "monthly"}>per month</option>
			</select>
			<label class="a-plan-active">
				<input type="checkbox" name="active" checked={!plan || plan.active === 1} /> active
			</label>
			<button type="submit">{plan ? "Update plan" : "Set plan"}</button>
		</form>
	</section>

	<section class="a-card" style="margin-top:1.25rem">
		<h2>Parent access</h2>
		<p class="a-muted" style="margin-top:-0.5rem;font-size:0.85rem">
			Invited parents can log in at <code>/portal</code> to see this child's daily report,
			attendance, and your announcements.
		</p>
		{
			inviteLink && (
				<div class="a-invite">
					<p>Copy this one-time link and send it to the parent (expires in 7 days):</p>
					<input class="a-invite-link" value={inviteLink} readonly onclick="this.select()" />
				</div>
			)
		}
		{
			parents.length > 0 && (
				<ul class="a-list a-parents">
					{parents.map((p) => (
						<li>
							<span>
								<strong>{p.name || p.email}</strong>
								{p.name && <span class="a-meta"> · {p.email}</span>}
							</span>
							<form method="POST" onsubmit="return confirm('Remove this parent’s access?')">
								<input type="hidden" name="intent" value="unlink" />
								<input type="hidden" name="user_id" value={p.id} />
								<button class="a-del" type="submit" title="Remove access">
									×
								</button>
							</form>
						</li>
					))}
				</ul>
			)
		}
		<form method="POST" class="a-form" style="margin-top:1rem">
			<input type="hidden" name="intent" value="invite" />
			<label>
				Invite a parent by email
				<input name="email" type="email" value={child.parent_email ?? ""} required />
			</label>
			<button type="submit">Generate invite link</button>
		</form>
	</section>

	<section class="a-card" style="margin-top:1.25rem">
		<h2>Private notes</h2>
		<p class="a-muted" style="margin-top:-0.5rem;font-size:0.85rem">Staff-only. Not shown to parents.</p>
		<form method="POST" class="a-form">
			<input type="hidden" name="intent" value="note" />
			<label>Add a note<textarea name="body" rows="3" required></textarea></label>
			<button type="submit">Save note</button>
		</form>
		{
			notes.length > 0 && (
				<ul class="a-notes">
					{notes.map((n) => (
						<li>
							<p>{n.body}</p>
							<span class="a-meta">
								{fmtDateTime(n.created_at)}
								{n.author && ` · ${n.author}`}
							</span>
						</li>
					))}
				</ul>
			)
		}
	</section>
</Admin>

<style is:global>
	.a-profile-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 1.25rem;
	}
	.a-profile-head h1 {
		margin: 0;
	}
	.a-sub {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin: 0.35rem 0 0;
		color: var(--a-muted);
		font-weight: 700;
		font-size: 0.9rem;
	}
	.a-att-inline {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.a-att-inline form {
		margin: 0;
	}
	.a-att-badge {
		font-size: 0.85rem;
		font-weight: 800;
		color: var(--a-coral);
	}
	.a-att-badge.done {
		color: #0a7d33;
	}
	.a-log {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.a-log select,
	.a-log input {
		font: inherit;
		padding: 0.5rem 0.6rem;
		border: 1.5px solid var(--a-line);
		border-radius: 10px;
	}
	.a-log input {
		flex: 1;
		min-width: 8rem;
	}
	.a-log select:focus,
	.a-log input:focus {
		outline: none;
		border-color: var(--a-coral);
	}
	.a-log button {
		background: var(--a-coral);
		color: #fff;
		border: none;
		border-radius: 999px;
		padding: 0.5rem 1.1rem;
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}
	.a-quick-label {
		font-size: 0.82rem;
		font-weight: 800;
		color: var(--a-muted);
		margin: 0 0 0.5rem;
	}
	.a-detailed {
		margin-top: 0.85rem;
	}
