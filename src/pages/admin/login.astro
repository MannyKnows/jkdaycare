---
export const prerender = false;
import { env } from "cloudflare:workers";
import Admin from "../../layouts/Admin.astro";
import { verifyPassword, createSession, COOKIE } from "../../lib/auth";

// No accounts yet? Send to the one-time setup.
const count = await env.DB.prepare("SELECT COUNT(*) AS n FROM users").first<{ n: number }>();
if ((count?.n ?? 0) === 0) return Astro.redirect("/admin/setup");

let error = "";
if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const email = String(form.get("email") ?? "").trim().toLowerCase();
	const password = String(form.get("password") ?? "");
	const user = await env.DB.prepare(
		"SELECT id, role, password_hash FROM users WHERE email = ?1",
	)
		.bind(email)
		.first<{ id: number; role: string; password_hash: string | null }>();
	const isStaff = user?.role === "owner" || user?.role === "staff";
	if (user && isStaff && (await verifyPassword(password, user.password_hash))) {
		const token = await createSession(user.id);
		Astro.cookies.set(COOKIE, token, {
			httpOnly: true,
			secure: true,
			sameSite: "lax",
			path: "/",
			maxAge: 14 * 86400,
		});
		return Astro.redirect("/admin");
	}
	error = "Wrong email or password.";
}
---

<Admin title="Log in">
	<div class="a-card" style="max-width:380px;margin:2rem auto;">
		<h1>J&amp;K Admin</h1>
		{error && <p class="a-error">{error}</p>}
		<form method="POST" class="a-form">
			<label>
				Email
				<input name="email" type="email" required autocomplete="username" />
			</label>
			<label>
				Password
				<input name="password" type="password" required autocomplete="current-password" />
			</label>
			<button type="submit">Log in</button>
		</form>
	</div>
</Admin>
