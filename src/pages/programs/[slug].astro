---
import Layout from "../../layouts/Page.astro";
import DailySchedule from "../../components/DailySchedule.astro";
import { PROGRAMS } from "../../data/site";
import { PHONE, PHONE_HREF } from "../../consts";

export function getStaticPaths() {
	return PROGRAMS.map((p) => ({ params: { slug: p.slug }, props: { program: p } }));
}

const { program } = Astro.props;
const title = `${program.name} (${program.ageRange}) | J&K Daycare — Springfield, MA`;
const description =
	`${program.name} at J&K Daycare in Springfield, MA. ${program.focus} ${program.blurb}`.slice(
		0,
		200,
	);
---

<Layout title={title} description={description} image="/montessori.jpg">
	<article class="program">
		<a class="crumb" href="/programs/">← All programs</a>
		<span class="age">{program.ageRange}</span>
		<h1>{program.name}</h1>
		<p class="lede">{program.blurb}</p>

		<div class="two-col">
			<div class="card">
				<h2>Program highlights</h2>
				<ul class="highlights">
					{program.highlights.map((h) => <li>{h}</li>)}
				</ul>
				<h2>Focus areas</h2>
				<p class="focus">{program.focus}</p>
				<div class="ctas">
					<a class="btn" href="/#tour">Schedule a tour</a>
					<a class="btn ghost" href={PHONE_HREF}>Call {PHONE}</a>
				</div>
			</div>

			<DailySchedule items={program.sampleDay} />
		</div>

		<section class="card faq">
			<h2>Questions parents ask</h2>
			<dl>
				{
					program.faqs.map((f) => (
						<div class="qa">
							<dt>{f.q}</dt>
							<dd>{f.a}</dd>
						</div>
					))
				}
			</dl>
		</section>
	</article>
</Layout>

<style>
	.program {
		width: 860px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2.5rem 1rem 3rem;
	}
	.crumb {
		display: inline-block;
		color: var(--blue);
		font-weight: 700;
		text-decoration: none;
		font-size: 0.92rem;
		margin-bottom: 1rem;
	}
	.age {
		display: inline-block;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--blue);
		background: rgba(242, 65, 80, 0.1);
		padding: 0.3rem 0.85rem;
		border-radius: 999px;
	}
	h1 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: clamp(2rem, 5vw, 2.8rem);
		margin: 0.6rem 0 0.5rem;
	}
	.lede {
		font-size: 1.15rem;
		color: var(--muted);
		max-width: 60ch;
		margin: 0 0 2rem;
	}
	.two-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
		align-items: start;
	}
	.card {
		background: #fff;
		border-radius: 22px;
		padding: 1.75rem;
		box-shadow: var(--card-shadow);
		text-align: left;
	}
	.card h2 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.25rem;
		margin: 0 0 0.75rem;
	}
	.card h2 + h2 {
		margin-top: 1.5rem;
	}
	.highlights {
		margin: 0;
		padding-left: 1.15rem;
		color: var(--muted);
	}
	.highlights li {
		margin: 0.4rem 0;
	}
	.focus {
		color: var(--muted);
		margin: 0;
	}
	.ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.5rem;
	}
	.btn {
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border-radius: 999px;
	}
	.btn.ghost {
		background: #fff;
		color: var(--blue);
		border: 2px solid var(--blue);
	}
	.faq {
		margin-top: 1.25rem;
	}
	.qa {
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--line);
	}
	.qa:last-child {
		border-bottom: none;
	}
	.faq dt {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		color: var(--ink);
		margin-bottom: 0.25rem;
	}
	.faq dd {
		margin: 0;
		color: var(--muted);
	}
	@media (max-width: 760px) {
		.two-col {
			grid-template-columns: 1fr;
		}
	}
</style>
