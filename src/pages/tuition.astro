---
import Layout from "../layouts/Page.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import { FAQS } from "../data/site";
import { PHONE, PHONE_HREF } from "../consts";
---

<Layout
	title="Tuition & Financial Assistance | J&K Daycare — Springfield, MA"
	description="Tuition for J&K Daycare in Springfield, MA. We accept childcare vouchers and financial assistance, including NEFWC. Call (413) 486-5978 for current pricing."
>
	<section class="wrap">
		<h1>Tuition & financial assistance</h1>
		<p class="lede">
			Simple, flexible options for East Forest Park families — with help navigating assistance if you
			need it.
		</p>

		<div class="cards">
			<div class="card">
				<h2>Tuition</h2>
				<p>Schedules vary, so we share current rates on a quick call or during your tour.</p>
				<div class="pricing-cta">
					<a class="btn" href={PHONE_HREF}>Call {PHONE}</a>
					<a class="btn ghost" href="/#tour">Request a tour</a>
				</div>
			</div>

			<div class="card assist">
				<h2>Financial assistance</h2>
				<p>
					We accept childcare vouchers and subsidies, including{" "}
					<strong>New England Farm Workers' Council (NEFWC)</strong>. Navigating assistance? We're
					glad to help you sort out the options.
				</p>
			</div>
		</div>

		<div class="faq-section">
			<h2>Frequently asked questions</h2>
			<FaqAccordion items={FAQS} />
		</div>
	</section>
</Layout>

<style>
	.wrap {
		width: 820px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2.5rem 1rem 3rem;
	}
	h1 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: clamp(2rem, 5vw, 2.8rem);
		margin: 0 0 0.5rem;
		text-align: center;
	}
	.lede {
		font-size: 1.15rem;
		color: var(--muted);
		max-width: 52ch;
		margin: 0 auto 2rem;
		text-align: center;
	}
	.cards {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}
	.card {
		background: #fff;
		border-radius: 22px;
		padding: 1.75rem;
		box-shadow: var(--card-shadow);
		text-align: left;
	}
	.card h2 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.3rem;
		margin: 0 0 0.6rem;
	}
	.card p {
		color: var(--muted);
		margin: 0 0 1.25rem;
		line-height: 1.6;
	}
	.card.assist p {
		margin-bottom: 0;
	}
	.pricing-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.btn {
		display: inline-block;
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		text-decoration: none;
		padding: 0.7rem 1.3rem;
		border-radius: 999px;
	}
	.btn.ghost {
		background: #fff;
		color: var(--blue);
		border: 2px solid var(--blue);
	}
	.faq-section {
		background: #fff;
		border-radius: 22px;
		padding: 1.75rem;
		box-shadow: var(--card-shadow);
		margin-top: 1.25rem;
	}
	.faq-section > h2 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.3rem;
		margin: 0 0 0.5rem;
	}
	@media (max-width: 640px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
