---
import Layout from "../layouts/Page.astro";
import { PHONE, PHONE_HREF, EMAIL, AREA_LINE, HOURS, LICENSE_NUMBER, GOOGLE_PROFILE_URL } from "../consts";
---

<Layout
	title="Contact & Visit | J&K Daycare — East Forest Park, Springfield, MA"
	description="Get in touch with J&K Daycare in East Forest Park, Springfield, MA. Call (413) 486-5978, email us, or request a tour, and see your commute time to us."
>
	<section class="wrap">
		<h1>Visit &amp; contact us</h1>
		<p class="lede">
			We'd love to meet your family. Call, email, or request a tour, and we'll follow up with current
			availability and next steps.
		</p>

		<div class="grid">
			<div class="card details">
				<h2>Get in touch</h2>
				<ul class="contact-list">
					<li>
						<span class="label">Phone</span>
						<a href={PHONE_HREF}>{PHONE}</a>
					</li>
					<li>
						<span class="label">Email</span>
						<a href={`mailto:${EMAIL}`}>{EMAIL}</a>
					</li>
					<li>
						<span class="label">Hours</span>
						<span>{HOURS}</span>
					</li>
					<li>
						<span class="label">Location</span>
						<span>{AREA_LINE}</span>
					</li>
					<li>
						<span class="label">License</span>
						<span>MA EEC #{LICENSE_NUMBER}</span>
					</li>
				</ul>
				<div class="ctas">
					<a class="btn" href="/#tour">Request a tour</a>
					<a class="btn ghost" href={GOOGLE_PROFILE_URL} target="_blank" rel="noopener">
						Find us on Google
					</a>
				</div>
			</div>

			<div class="map-col">
				<p class="map-cap">Estimate your commute to us</p>
				<div class="map-embed">
					<iframe
						src="https://storage.googleapis.com/maps-solutions-utp5kulvlh/commutes/dqo5/commutes.html"
						title="Map and commute times to J&K Daycare"
						loading="lazy"></iframe>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.wrap {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2.5rem 1rem 3rem;
	}
	h1 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: clamp(2rem, 5vw, 2.8rem);
		margin: 0 0 0.5rem;
		text-align: center;
	}
	.lede {
		font-size: 1.15rem;
		color: var(--muted);
		max-width: 56ch;
		margin: 0 auto 2rem;
		text-align: center;
	}
	.grid {
		display: grid;
		grid-template-columns: 1fr 1.25fr;
		gap: 1.25rem;
		align-items: stretch;
	}
	.card {
		background: #fff;
		border-radius: 22px;
		padding: 1.75rem;
		box-shadow: var(--card-shadow);
		text-align: left;
	}
	.card h2 {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 800;
		font-size: 1.3rem;
		margin: 0 0 1rem;
	}
	.contact-list {
		list-style: none;
		margin: 0 0 1.5rem;
		padding: 0;
	}
	.contact-list li {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		padding: 0.65rem 0;
		border-bottom: 1px solid var(--line);
	}
	.contact-list li:last-child {
		border-bottom: none;
	}
	.contact-list .label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--soft);
	}
	.contact-list a {
		color: var(--blue);
		text-decoration: none;
		font-weight: 700;
	}
	.contact-list a:hover {
		text-decoration: underline;
	}
	.ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.btn {
		display: inline-block;
		background: var(--blue);
		color: #fff;
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		text-decoration: none;
		padding: 0.7rem 1.3rem;
		border-radius: 999px;
	}
	.btn.ghost {
		background: #fff;
		color: var(--blue);
		border: 2px solid var(--blue);
	}
	.map-col {
		display: flex;
		flex-direction: column;
	}
	.map-cap {
		font-family: "Baloo 2", "Nunito", sans-serif;
		font-weight: 700;
		color: var(--muted);
		margin: 0 0 0.5rem;
		font-size: 0.95rem;
	}
	.map-embed {
		flex: 1;
		border-radius: 22px;
		overflow: hidden;
		box-shadow: var(--card-shadow);
		background: #eef2f7;
		min-height: 460px;
	}
	.map-embed iframe {
		width: 100%;
		height: 100%;
		min-height: 460px;
		border: 0;
		display: block;
	}
	@media (max-width: 820px) {
		.grid {
			grid-template-columns: 1fr;
		}
		.map-embed,
		.map-embed iframe {
			min-height: 520px;
		}
	}
</style>
